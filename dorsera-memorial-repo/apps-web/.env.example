# Copia este archivo a .env.local (desarrollo) y configura los mismos
# valores como Environment Variables en el proyecto de Vercel (producción).

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública del sitio. En desarrollo:
#   NEXT_PUBLIC_SITE_URL=http://localhost:3000
# En producción, la URL real del dominio (sin slash final):
#   NEXT_PUBLIC_SITE_URL=https://memorial.tudominio.com
# Se usa como emailRedirectTo en el registro (lib/actions/auth.ts) — debe
# coincidir con una de las Redirect URLs configuradas en Supabase
# (Authentication → URL Configuration), agregando /auth/callback al final.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
