# Copia este archivo a .env.local y completa con los valores de tu proyecto Supabase
# (Project Settings → API en el dashboard de Supabase)

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo se usa server-side / en Edge Functions. Nunca exponer al cliente.
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# URL pública base usada por la Edge Function generate-qr
# PUBLIC_BASE_URL=https://dorsera.com
